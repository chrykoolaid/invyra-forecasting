# Invyra Forecasting API production deployment example
# Copy values into your deployment host environment settings.

# Required for hosted Base44 browser access. Add exact hosted Base44 origins only. Do not use *.
INVYRA_FORECASTING_ALLOWED_ORIGINS=https://app.base44.com

# Optional runtime port. Many hosts inject PORT automatically.
INVYRA_FORECASTING_PORT=8000

# Optional persisted storage paths. Configure durable storage if your host supports volumes.
INVYRA_FORECASTING_SNAPSHOT_DIR=./data/snapshots
INVYRA_FORECASTING_AUDIT_LOG_PATH=./data/audit/events.jsonl
INVYRA_FORECASTING_ACCURACY_LOG_PATH=./data/accuracy/accuracy.jsonl
INVYRA_FORECASTING_REPORT_EXPORT_DIR=./data/reports
